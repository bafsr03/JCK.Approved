{% comment %}
  JCK Approved — Manifesto / Brand Statement Section
  Split dark/light with oversized typography and editorial body copy
{% endcomment %}

<section class="jck-mani" id="jck-mani-{{ section.id }}" aria-label="Our Manifesto">
  <div class="jck-mani__dark" style="background:#886275;color:#F4F0E7;">
    <div class="jck-mani__dark-inner">
      <span class="jck-label jck-mani__label jck-reveal" style="--i:0; color:rgba(244,240,231,0.5);">
        03 ── About Us
      </span>

      <h2 class="jck-mani__headline">
        <span class="jck-mani__line" style="--i:0; color:#F4F0E7;">
          <span style="color:#F4F0E7;">We Find</span>
        </span>
        <span class="jck-mani__line jck-mani__line--outline" style="--i:1; color:transparent; -webkit-text-stroke:1.5px rgba(244,240,231,0.65);">
          <span style="color:transparent; -webkit-text-stroke:1.5px rgba(244,240,231,0.65);">The Heat</span>
        </span>
        <span class="jck-mani__line" style="--i:2; color:#F4F0E7;">
          <span style="color:#F4F0E7;">You Want.</span>
        </span>
      </h2>

      <div class="jck-mani__stats jck-reveal" style="--i:3">
        <div class="jck-mani__stat">
          <span class="jck-mani__stat-num" data-count="500" style="color:#F4F0E7;">00</span>
          <span class="jck-mani__stat-label" style="color:rgba(244,240,231,0.5);">Pieces Curated</span>
        </div>
        <div class="jck-mani__stat">
          <span class="jck-mani__stat-num" data-count="100" style="color:#F4F0E7;">00</span>
          <span class="jck-mani__stat-label" style="color:rgba(244,240,231,0.5);">% Authenticated</span>
        </div>
        <div class="jck-mani__stat">
          <span class="jck-mani__stat-num" data-count="0" style="color:#F4F0E7;">00</span>
          <span class="jck-mani__stat-label" style="color:rgba(244,240,231,0.5);">Fakes — Ever</span>
        </div>
      </div>
    </div>
  </div>

  <div class="jck-mani__light">
    {%- comment -%} Cat Noir — pops up on scroll, eyes follow cursor {%- endcomment -%}
    <div class="jck-cat-wrap" aria-hidden="true">
      <svg viewBox="190 1760 1060 850" width="100%" fill="none" preserveAspectRatio="xMidYMax meet" xmlns="http://www.w3.org/2000/svg">
        <g transform="translate(578,2556) scale(1.83,1.83)">
          <g transform="matrix(1,0,0,1,-336.062,-398.908)">

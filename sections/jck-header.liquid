{% comment %}
  JCK Approved — Unified Header
  Combines announcement bar + main navigation in one clean, on-brand section.
  Replaces the stock `header-announcements` and `header` sections.
{% endcomment %}

{%- liquid
  assign menu_handle = section.settings.menu | default: 'main-menu'
  assign main_menu = linklists[menu_handle]
-%}

<div class="jck-header {% if template.name == 'index' %}jck-header--hide-logo-at-top{% endif %}" id="jck-header-{{ section.id }}">

  {%- comment -%} ── ANNOUNCEMENT BAR — vertical word-roller ─────────────── {%- endcomment -%}
  {%- if section.settings.show_announcement -%}
    <div class="jck-header__announce" aria-label="Announcements">
      <span class="jck-header__announce-flank jck-header__announce-flank--left" aria-hidden="true">✦</span>
      <div class="jck-header__announce-stage" aria-live="polite">
        <div class="jck-header__announce-roll">
          <span class="jck-header__announce-line">{{ section.settings.announce_1 | default: 'New Drops Weekly' }}</span>
          <span class="jck-header__announce-line">{{ section.settings.announce_2 | default: 'Authenticated · Curated · JCK Approved' }}</span>
          <span class="jck-header__announce-line">{{ section.settings.announce_3 | default: 'Free Shipping over $100' }}</span>
          <span class="jck-header__announce-line">{{ section.settings.announce_4 | default: 'No Restocks · Ever' }}</span>
          {%- comment -%} Clone of first line so the loop wraps seamlessly. {%- endcomment -%}
          <span class="jck-header__announce-line" aria-hidden="true">{{ section.settings.announce_1 | default: 'New Drops Weekly' }}</span>
        </div>
      </div>
      <span class="jck-header__announce-flank jck-header__announce-flank--right" aria-hidden="true">✦</span>
    </div>
  {%- endif -%}

  {%- comment -%} ── MAIN NAVBAR ──────────────────────────────────────────── {%- endcomment -%}
  <nav class="jck-header__nav" aria-label="Primary">
    <div class="jck-header__nav-inner">

      {%- comment -%} Logo (left) {%- endcomment -%}
      <a href="{{ routes.root_url }}" class="jck-header__logo" aria-label="JCK Approved — Home">
        <img
          src="{{ 'jck-title.png' | asset_url }}"
          alt="JCK Approved"
          width="160"
          height="68"
          loading="eager"
        >
      </a>

      {%- comment -%} Menu (center) — inline color+font lock so no inherited
                       Shopify scheme can repaint the words. {%- endcomment -%}
      {%- assign nav_inline = "color: #3f3227; font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;" -%}
      <ul class="jck-header__menu" role="menubar">
        {%- if main_menu != blank and main_menu.links.size > 0 -%}
          {%- for link in main_menu.links -%}
            <li role="none">
              <a href="{{ link.url }}" class="jck-header__link {% if link.active %}is-active{% endif %}" role="menuitem" style="{{ nav_inline }}">
                {{ link.title }}
              </a>
            </li>
          {%- endfor -%}
        {%- else -%}
          <li role="none"><a href="/collections/all" class="jck-header__link" role="menuitem" style="{{ nav_inline }}">Shop</a></li>
          <li role="none"><a href="/pages/story"    class="jck-header__link" role="menuitem" style="{{ nav_inline }}">Story</a></li>
          <li role="none"><a href="/pages/contact"  class="jck-header__link" role="menuitem" style="{{ nav_inline }}">Contact</a></li>
        {%- endif -%}
      </ul>

      {%- comment -%} Utilities (right) — inline color locks icons to black. {%- endcomment -%}
      {%- assign util_inline = "color: #3f3227;" -%}
      <div class="jck-header__utils">
        <a href="{{ routes.search_url }}" class="jck-header__util" aria-label="Search" style="{{ util_inline }}">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>

        <button type="button" class="jck-header__util" aria-label="Account" data-jck-open="account" style="{{ util_inline }} background:transparent; border:none; cursor:pointer; padding:0;">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="7" r="3.25" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3.75 16.5C4.5 13.5 7 12 10 12C13 12 15.5 13.5 16.25 16.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>

        <button type="button" class="jck-header__util jck-header__cart" aria-label="Cart ({{ cart.item_count }} items)" data-jck-open="cart" style="{{ util_inline }} background:transparent; border:none; cursor:pointer; padding:0;">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 6.5H16L14.75 14.25C14.65 14.85 14.15 15.25 13.55 15.25H6.45C5.85 15.25 5.35 14.85 5.25 14.25L4 6.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M7 6.5V5C7 3.62 8.12 2.5 9.5 2.5H10.5C11.88 2.5 13 3.62 13 5V6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="jck-header__cart-count" data-jck-cart-count{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
        </button>

        <button type="button" class="jck-header__burger" aria-label="Open menu" aria-expanded="false" data-jck-burger>
          <span></span><span></span><span></span>
        </button>
      </div>

    </div>
  </nav>

  {%- comment -%} ── MOBILE NAV DRAWER (top-down) ─────────────────────────── {%- endcomment -%}
  <div class="jck-header__drawer" data-jck-drawer aria-hidden="true">
    <ul class="jck-header__drawer-menu">
      {%- if main_menu != blank and main_menu.links.size > 0 -%}
        {%- for link in main_menu.links -%}
          <li><a href="{{ link.url }}" class="jck-header__drawer-link">{{ link.title }}</a></li>
        {%- endfor -%}
      {%- else -%}
        <li><a href="/collections/all" class="jck-header__drawer-link">Shop</a></li>
        <li><a href="/pages/story"    class="jck-header__drawer-link">Story</a></li>
        <li><a href="/pages/contact"  class="jck-header__drawer-link">Contact</a></li>
      {%- endif -%}
      <li><button type="button" class="jck-header__drawer-link jck-header__drawer-link--secondary" data-jck-open="account" style="background:transparent;border:none;cursor:pointer;color:inherit;font:inherit;letter-spacing:inherit;text-transform:inherit;padding:18px 0;width:100%;text-align:left;">Account</button></li>
    </ul>
  </div>

  {%- comment -%} ── CART DRAWER (right side panel) ───────────────────────── {%- endcomment -%}
  <aside class="jck-side jck-side--cart" data-jck-side="cart" aria-hidden="true" aria-label="Cart">
    <div class="jck-side__header">
      <h2 class="jck-side__title">Your Bag <span class="jck-side__count" data-jck-cart-count-label></span></h2>
      <button type="button" class="jck-side__close" data-jck-close aria-label="Close cart">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <path d="M5 5L17 17M17 5L5 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="jck-side__body" data-jck-cart-body>
      <div class="jck-side__empty">Your bag is empty.</div>
    </div>
    <div class="jck-side__footer" data-jck-cart-footer hidden>
      <div class="jck-side__row">
        <span>Subtotal</span>
        <span data-jck-cart-subtotal>$0.00</span>
      </div>
      <p class="jck-side__note">Shipping &amp; taxes calculated at checkout.</p>
      <a href="{{ routes.cart_url }}/checkout" class="jck-side__cta jck-side__cta--primary">Checkout →</a>
      <a href="{{ routes.cart_url }}" class="jck-side__cta jck-side__cta--ghost">View bag</a>
    </div>
  </aside>

  {%- comment -%} ── ACCOUNT / LOGIN DRAWER (right side panel) ────────────── {%- endcomment -%}
  <aside class="jck-side jck-side--account" data-jck-side="account" aria-hidden="true" aria-label="Account">
    <div class="jck-side__header">
      <h2 class="jck-side__title">{% if customer %}Account{% else %}Sign In{% endif %}</h2>
      <button type="button" class="jck-side__close" data-jck-close aria-label="Close">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <path d="M5 5L17 17M17 5L5 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="jck-side__body">
      {%- if customer -%}
        <p class="jck-side__hello">Hi, {{ customer.first_name | default: customer.email }}</p>
        <ul class="jck-side__list">
          <li><a href="{{ routes.account_url }}">Account home</a></li>
          <li><a href="{{ routes.account_addresses_url }}">Addresses</a></li>
          <li><a href="{{ routes.account_logout_url }}">Log out</a></li>
        </ul>
      {%- else -%}
        {%- form 'customer_login', class: 'jck-side__form' -%}
          {{ form.errors | default_errors }}
          <label class="jck-side__field">
            <span>Email</span>
            <input type="email" name="customer[email]" required autocomplete="email" autocapitalize="off" autocorrect="off">
          </label>
          <label class="jck-side__field">
            <span>Password</span>
            <input type="password" name="customer[password]" required autocomplete="current-password">
          </label>
          <button type="submit" class="jck-side__cta jck-side__cta--primary">Sign In</button>
        {%- endform -%}
        <div class="jck-side__alts">
          <a href="{{ routes.account_register_url }}">New here? Create an account →</a>
          <a href="{{ routes.account_recover_url }}">Forgot your password?</a>
        </div>
      {%- endif -%}
    </div>
  </aside>

  {%- comment -%} ── Shared backdrop ──────────────────────────────────────── {%- endcomment -%}
  <div class="jck-side-backdrop" data-jck-backdrop aria-hidden="true"></div>

</div>

<script>
(function () {
  var root   = document.getElementById('jck-header-{{ section.id }}');
  if (!root) return;
  var burger = root.querySelector('[data-jck-burger]');
  var navDrawer = root.querySelector('[data-jck-drawer]');
  var sides    = root.querySelectorAll('[data-jck-side]');
  var backdrop = root.querySelector('[data-jck-backdrop]');
  var cartBody = root.querySelector('[data-jck-cart-body]');
  var cartFooter = root.querySelector('[data-jck-cart-footer]');
  var cartSubtotalEl = root.querySelector('[data-jck-cart-subtotal]');
  var cartCountEls = document.querySelectorAll('[data-jck-cart-count]');
  var cartCountLabel = root.querySelector('[data-jck-cart-count-label]');
  var moneyFmt = {{ shop.money_format | json }};

  // ── Drawer state ────────────────────────────────────────────────────
  function closeAll() {
    if (navDrawer) {
      navDrawer.classList.remove('is-open');
      navDrawer.setAttribute('aria-hidden', 'true');
    }
    if (burger) {
      burger.classList.remove('is-open');
      burger.setAttribute('aria-expanded', 'false');
    }
    sides.forEach(function (el) {
      el.classList.remove('is-open');
      el.setAttribute('aria-hidden', 'true');
    });
    if (backdrop) backdrop.classList.remove('is-open');
    document.body.classList.remove('jck-no-scroll');
  }
  function openNav() {
    closeAll();
    if (!navDrawer) return;
    navDrawer.classList.add('is-open');
    navDrawer.setAttribute('aria-hidden', 'false');
    if (burger) {
      burger.classList.add('is-open');
      burger.setAttribute('aria-expanded', 'true');
    }
    document.body.classList.add('jck-no-scroll');
  }
  function openSide(name) {
    closeAll();
    var target = root.querySelector('[data-jck-side="' + name + '"]');
    if (!target) return;
    target.classList.add('is-open');
    target.setAttribute('aria-hidden', 'false');
    if (backdrop) backdrop.classList.add('is-open');
    document.body.classList.add('jck-no-scroll');
    if (name === 'cart') refreshCart();
  }

  if (burger) {
    burger.addEventListener('click', function () {
      if (navDrawer && navDrawer.classList.contains('is-open')) closeAll();
      else openNav();
    });
  }
  if (navDrawer) {
    navDrawer.addEventListener('click', function (e) {
      if (e.target.closest('a')) closeAll();
    });
  }
  root.querySelectorAll('[data-jck-open]').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      openSide(btn.getAttribute('data-jck-open'));
    });
  });
  root.querySelectorAll('[data-jck-close]').forEach(function (btn) {
    btn.addEventListener('click', closeAll);
  });
  if (backdrop) backdrop.addEventListener('click', closeAll);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeAll();
  });
  window.addEventListener('resize', function () {
    if (window.innerWidth > 900 && navDrawer && navDrawer.classList.contains('is-open')) closeAll();
  });

  // Shadow on scroll
  var nav = root.querySelector('.jck-header__nav');
  if (nav) {
    window.addEventListener('scroll', function () {
      nav.classList.toggle('is-scrolled', (window.scrollY || 0) > 8);
    }, { passive: true });
  }

  // ── Cart drawer logic ──────────────────────────────────────────────
  function formatMoney(cents) {
    var amt = (cents / 100).toFixed(2);
    if (!moneyFmt) return '$' + amt;
    return moneyFmt.replace(/\{\{\s*amount[^}]*\}\}/, amt);
  }
  function updateCartCounts(count) {
    cartCountEls.forEach(function (el) {
      el.textContent = count;
      if (count > 0) el.removeAttribute('hidden');
      else el.setAttribute('hidden', '');
    });
    if (cartCountLabel) cartCountLabel.textContent = count ? '(' + count + ')' : '';
  }
  function renderCart(cart) {
    updateCartCounts(cart.item_count);
    if (!cart.items || !cart.items.length) {
      cartBody.innerHTML = '<div class="jck-side__empty">Your bag is empty.<br><br><a href="/collections/all" class="jck-side__cta jck-side__cta--ghost" style="display:inline-block;">Browse Drops</a></div>';
      if (cartFooter) cartFooter.hidden = true;
      return;
    }
    var html = '<ul class="jck-side__items">';
    cart.items.forEach(function (item) {
      var img = item.image ? item.image.replace(/(\.[a-z]+)(\?.*)?$/, '_120x$1$2') : '';
      html += '<li class="jck-side__item" data-line-key="' + item.key + '">';
      html += '  <a href="' + item.url + '" class="jck-side__item-img">';
      if (img) html += '<img src="' + img + '" alt="' + (item.product_title || '') + '" loading="lazy">';
      html += '  </a>';
      html += '  <div class="jck-side__item-meta">';
      html += '    <a href="' + item.url + '" class="jck-side__item-title">' + item.product_title + '</a>';
      if (item.variant_title && item.variant_title !== 'Default Title') {
        html += '<div class="jck-side__item-variant">' + item.variant_title + '</div>';
      }
      html += '    <div class="jck-side__item-bottom">';
      html += '      <div class="jck-side__qty">';
      html += '        <button type="button" data-jck-qty="' + item.key + '" data-jck-qty-delta="-1" aria-label="Decrease">−</button>';
      html += '        <span>' + item.quantity + '</span>';
      html += '        <button type="button" data-jck-qty="' + item.key + '" data-jck-qty-delta="1" aria-label="Increase">+</button>';
      html += '      </div>';
      html += '      <div class="jck-side__item-price">' + formatMoney(item.final_line_price) + '</div>';
      html += '    </div>';
      html += '    <button type="button" class="jck-side__item-remove" data-jck-remove="' + item.key + '">Remove</button>';
      html += '  </div>';
      html += '</li>';
    });
    html += '</ul>';
    cartBody.innerHTML = html;
    if (cartSubtotalEl) cartSubtotalEl.textContent = formatMoney(cart.total_price);
    if (cartFooter) cartFooter.hidden = false;
    wireCartActions();
  }
  function wireCartActions() {
    cartBody.querySelectorAll('[data-jck-qty]').forEach(function (b) {
      b.addEventListener('click', function () {
        var key = b.getAttribute('data-jck-qty');
        var delta = parseInt(b.getAttribute('data-jck-qty-delta'), 10);
        var item = cartBody.querySelector('[data-line-key="' + key + '"]');
        var span = item && item.querySelector('.jck-side__qty span');
        var current = span ? parseInt(span.textContent, 10) : 1;
        changeLine(key, Math.max(0, current + delta));
      });
    });
    cartBody.querySelectorAll('[data-jck-remove]').forEach(function (b) {
      b.addEventListener('click', function () {
        changeLine(b.getAttribute('data-jck-remove'), 0);
      });
    });
  }
  function refreshCart() {
    if (!cartBody) return;
    fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
      .then(function (r) { return r.json(); })
      .then(renderCart)
      .catch(function () {
        cartBody.innerHTML = '<div class="jck-side__empty">Couldn’t load your bag. <a href="/cart">View on cart page</a></div>';
      });
  }
  function changeLine(key, quantity) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: key, quantity: quantity })
    })
    .then(function (r) { return r.json(); })
    .then(renderCart)
    .catch(refreshCart);
  }

  // Initial cart count (in case prerendered count is stale)
  refreshCart();

  // Listen for add-to-cart events from elsewhere (Shopify themes commonly
  // dispatch a 'cart:updated' or PUB/SUB event). Re-fetch on any of them.
  ['cart:updated', 'cart:refresh', 'cart-updated'].forEach(function (evt) {
    document.addEventListener(evt, refreshCart);
  });
  // Also re-fetch if the cart page form is submitted (fallback).
})();
</script>

{% stylesheet %}

/* ─── Wrapper ──────────────────────────────────────────────────────── */
/* Flatten the wrapper chain so the announcement bar and navbar become
   layout children of <body>. The navbar can then sticky against the full
   page; the announcement bar stays in normal flow and scrolls away. */
#header-group:has(.jck-header),
.jck-header-wrapper,
.jck-header {
  display: contents !important;
}
.jck-header {
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  color: #3f3227;
  /* Override any inherited Shopify color-scheme variables so nothing
     can cascade white text/icons into the navbar. */
  --color-foreground: #3f3227 !important;
  --color-foreground-rgb: 6 6 6 !important;
  --color-foreground-heading: #3f3227 !important;
  --color-primary: #3f3227 !important;
}
/* Force the cream navbar to use black foreground.
   Targeted selectors only — keeps hover-invert (white on black) working. */
.jck-header__nav { color: #3f3227 !important; }
.jck-header__nav a,
.jck-header__nav button { color: inherit; }

body.jck-no-scroll { overflow: hidden; }

/* ─── Announcement bar — vertical word-roller ──────────────────────── */
.jck-header__announce {
  --jck-announce-height: 44px;
  background: #886275;
  color: #F4F0E7;
  height: var(--jck-announce-height);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: clamp(18px, 4vw, 48px);
  border-bottom: 1px solid rgba(244,240,231,0.06);
  overflow: hidden;
  position: relative;
}
.jck-header__announce-flank {
  color: rgba(244,240,231,0.35);
  font-size: 0.7rem;
  letter-spacing: 0;
  flex: 0 0 auto;
  animation: jck-header-flank-spin 12s linear infinite;
}
.jck-header__announce-flank--right { animation-direction: reverse; }
@keyframes jck-header-flank-spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}
.jck-header__announce-stage {
  height: var(--jck-announce-height);
  overflow: hidden;
  position: relative;
  flex: 0 1 auto;
  /* Soft mask so each line eases in/out of the slot rather than hard-clipping. */
  -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #3f3227 22%, #3f3227 78%, transparent 100%);
          mask-image: linear-gradient(to bottom, transparent 0%, #3f3227 22%, #3f3227 78%, transparent 100%);
}
.jck-header__announce-roll {
  display: flex;
  flex-direction: column;
  animation: jck-header-announce-roll 18s cubic-bezier(0.83, 0, 0.17, 1) infinite;
}
.jck-header__announce-line {
  height: var(--jck-announce-height);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 0.84rem;
  font-weight: 500;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #F4F0E7 !important;
  white-space: nowrap;
  padding: 0 8px;
}
/* 4 messages → 5 keyframe stops (each holds ~75% of its slice, transitions 25%).
   The roll lands on the 5th slot (clone of slot 1) and snaps back to 0 for a
   seamless loop. */
@keyframes jck-header-announce-roll {
  0%,  18%  { transform: translateY(0);                              }
  25%, 43%  { transform: translateY(calc(var(--jck-announce-height) * -1)); }
  50%, 68%  { transform: translateY(calc(var(--jck-announce-height) * -2)); }
  75%, 93%  { transform: translateY(calc(var(--jck-announce-height) * -3)); }
  100%      { transform: translateY(calc(var(--jck-announce-height) * -4)); }
}
.jck-header__announce:hover .jck-header__announce-roll,
.jck-header__announce:hover .jck-header__announce-flank {
  animation-play-state: paused;
}
@media (prefers-reduced-motion: reduce) {
  .jck-header__announce-roll,
  .jck-header__announce-flank { animation: none; }
}

/* ─── Main nav ─────────────────────────────────────────────────────── */
.jck-header__nav {
  position: sticky;
  top: 0;
  z-index: 200;
  background: #F4F0E7 !important;       /* solid cream — no blur-through to dark content */
  border-bottom: 1px solid rgba(63,50,39,0.08);
  transition: box-shadow 0.3s ease, background 0.3s ease;
}
.jck-header__nav.is-scrolled {
  background: #F4F0E7 !important;
  box-shadow: 0 8px 24px rgba(63,50,39,0.06);
}
.jck-header__nav-inner {
  max-width: 1480px;
  margin: 0 auto;
  padding: 0 clamp(20px, 4vw, 56px);
  height: clamp(64px, 9vh, 84px);
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: clamp(16px, 3vw, 40px);
}

/* Logo — visible by default. On the index template only, hide at top and
   reveal on scroll (the .jck-header--hide-logo-at-top modifier is added
   by Liquid when template.name == 'index'). */
.jck-header__logo {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
  justify-self: start;
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
  transition:
    opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1),
    transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
}
.jck-header__logo:hover { transform: scale(1.04); }
.jck-header__logo img {
  display: block;
  height: clamp(28px, 4vh, 40px);
  width: auto;
}

/* Index-only: hide logo at top, reveal once user scrolls. */
.jck-header--hide-logo-at-top .jck-header__logo {
  opacity: 0;
  transform: translateY(-8px);
  pointer-events: none;
}
.jck-header--hide-logo-at-top .jck-header__nav.is-scrolled .jck-header__logo {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}
.jck-header--hide-logo-at-top .jck-header__nav.is-scrolled .jck-header__logo:hover {
  transform: scale(1.04);
}

/* Menu */
.jck-header__menu {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  gap: clamp(24px, 3vw, 48px);
  justify-self: center;
}
.jck-header__link {
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 0.92rem;
  font-weight: 500;
  letter-spacing: 0.26em;
  text-transform: uppercase;
  color: #3f3227 !important;
  text-decoration: none;
  position: relative;
  padding: 6px 0;
  transition: color 0.2s ease;
}
.jck-header__link::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1.5px;
  background: #d76577 !important;
  transform: scaleX(0);
  transform-origin: right;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}
.jck-header__link:hover::after,
.jck-header__link.is-active::after {
  transform: scaleX(1);
  transform-origin: left;
}
.jck-header__link.is-active { color: #d76577; }

/* Utilities */
.jck-header__utils {
  display: flex;
  align-items: center;
  gap: clamp(10px, 1.4vw, 18px);
  justify-self: end;
}
.jck-header__util {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: transparent;
  color: #3f3227 !important;
  text-decoration: none;
  position: relative;
  transition: background 0.25s ease, color 0.25s ease, transform 0.25s ease;
}
.jck-header__util:hover {
  background: #d76577 !important;
  color: #F4F0E7 !important;
  transform: translateY(-1px);
}
.jck-header__util svg {
  display: block;
  color: inherit;
  stroke: currentColor;
}
.jck-header__util svg path,
.jck-header__util svg circle { stroke: currentColor; }

/* Cart count badge */
.jck-header__cart-count {
  position: absolute;
  top: -2px;
  right: -2px;
  min-width: 18px;
  height: 18px;
  padding: 0 5px;
  border-radius: 9px;
  background: #d76577;
  color: #F4F0E7;
  font-family: 'Sifonn', sans-serif;
  font-size: 0.6rem;
  letter-spacing: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  border: 2px solid #F4F0E7;
}
.jck-header__util:hover .jck-header__cart-count {
  background: #F4F0E7;
  color: #d76577;
  border-color: #d76577;
}

/* Hamburger (mobile only) */
.jck-header__burger {
  display: none;
  width: 40px;
  height: 40px;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 0;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 5px;
  border-radius: 50%;
  transition: background 0.25s ease;
}
.jck-header__burger:hover { background: rgba(63,50,39,0.06); }
.jck-header__burger span {
  display: block;
  width: 20px;
  height: 1.5px;
  background: #3f3227 !important;
  transition: transform 0.35s ease, opacity 0.25s ease;
  transform-origin: center;
}
.jck-header__burger.is-open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.jck-header__burger.is-open span:nth-child(2) { opacity: 0; }
.jck-header__burger.is-open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

/* ─── Side drawers (cart + account) ────────────────────────────────── */
.jck-side-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(63,50,39,0.45);
  z-index: 998;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease;
}
.jck-side-backdrop.is-open { opacity: 1; pointer-events: auto; }

.jck-side {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: min(420px, 100vw);
  background: #F4F0E7 !important;
  color: #3f3227 !important;
  z-index: 999;
  transform: translateX(100%);
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  display: flex;
  flex-direction: column;
  box-shadow: -16px 0 40px rgba(63,50,39,0.08);
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
}
.jck-side.is-open { transform: translateX(0); }

.jck-side__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22px 24px;
  border-bottom: 1px solid rgba(63,50,39,0.08);
}
.jck-side__title {
  margin: 0;
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 0.92rem;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: #3f3227 !important;
}
.jck-side__count {
  margin-left: 6px;
  color: rgba(63,50,39,0.45) !important;
  font-size: 0.85em;
  letter-spacing: 0;
}
.jck-side__close {
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 6px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #3f3227 !important;
  border-radius: 50%;
  transition: background 0.2s ease;
}
.jck-side__close:hover { background: rgba(63,50,39,0.06); }

.jck-side__body {
  flex: 1;
  overflow-y: auto;
  padding: 18px 24px 24px;
}
.jck-side__empty {
  font-family: var(--font-body--family, 'Inter', sans-serif);
  font-size: 0.92rem;
  line-height: 1.6;
  color: rgba(63,50,39,0.6) !important;
  padding: 32px 0;
  text-align: center;
}
.jck-side__footer {
  border-top: 1px solid rgba(63,50,39,0.08);
  padding: 18px 24px 24px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.jck-side__row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 0.86rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #3f3227 !important;
}
.jck-side__note {
  font-family: var(--font-body--family, 'Inter', sans-serif);
  font-size: 0.72rem;
  color: rgba(63,50,39,0.5) !important;
  margin: -2px 0 8px;
  text-transform: none;
  letter-spacing: 0;
}
.jck-side__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16px 22px;
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 0.78rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  text-decoration: none;
  border: 1.5px solid #3f3227;
  transition: background 0.25s ease, color 0.25s ease, transform 0.2s ease;
}
.jck-side__cta--primary {
  background: #d76577 !important;
  color: #F4F0E7 !important;
  border-color: #d76577 !important;
}
.jck-side__cta--primary:hover { background: #ec904d !important; border-color: #ec904d !important; }
.jck-side__cta--ghost {
  background: transparent;
  color: #3f3227 !important;
}
.jck-side__cta--ghost:hover {
  background: #d76577 !important;
  border-color: #d76577 !important;
  color: #F4F0E7 !important;
}

/* Cart line items */
.jck-side__items {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.jck-side__item {
  display: grid;
  grid-template-columns: 84px 1fr;
  gap: 14px;
  padding-bottom: 16px;
  border-bottom: 1px solid rgba(63,50,39,0.06);
}
.jck-side__item:last-child { border-bottom: none; }
.jck-side__item-img {
  display: block;
  width: 84px;
  height: 96px;
  background: #ece9e3;
  overflow: hidden;
}
.jck-side__item-img img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.jck-side__item-meta {
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 0;
}
.jck-side__item-title {
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 0.84rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #3f3227 !important;
  text-decoration: none;
  line-height: 1.3;
}
.jck-side__item-variant {
  font-family: var(--font-body--family, 'Inter', sans-serif);
  font-size: 0.72rem;
  color: rgba(63,50,39,0.55) !important;
}
.jck-side__item-bottom {
  margin-top: auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.jck-side__qty {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  border: 1px solid rgba(63,50,39,0.18);
}
.jck-side__qty button {
  width: 26px;
  height: 26px;
  background: transparent;
  border: none;
  font-size: 0.95rem;
  cursor: pointer;
  color: #3f3227 !important;
}
.jck-side__qty button:hover { background: rgba(63,50,39,0.05); }
.jck-side__qty span {
  min-width: 22px;
  text-align: center;
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 0.84rem;
  color: #3f3227 !important;
}
.jck-side__item-price {
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 0.84rem;
  letter-spacing: 0.04em;
  color: #3f3227 !important;
}
.jck-side__item-remove {
  margin-top: 6px;
  background: transparent;
  border: none;
  padding: 0;
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 0.66rem;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: rgba(63,50,39,0.55) !important;
  text-decoration: underline;
  cursor: pointer;
  align-self: flex-start;
}
.jck-side__item-remove:hover { color: #3f3227 !important; }

/* Account drawer */
.jck-side__hello {
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 1.1rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #3f3227 !important;
  margin: 0 0 18px;
}
.jck-side__list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
}
.jck-side__list a {
  display: block;
  padding: 16px 0;
  border-bottom: 1px solid rgba(63,50,39,0.08);
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 0.78rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #3f3227 !important;
  text-decoration: none;
  transition: padding-left 0.3s cubic-bezier(0.16,1,0.3,1);
}
.jck-side__list a:hover { padding-left: 8px; }

.jck-side__form {
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.jck-side__field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.jck-side__field span {
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 0.66rem;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: rgba(63,50,39,0.6) !important;
}
.jck-side__field input {
  padding: 12px 14px;
  border: 1.5px solid rgba(63,50,39,0.25);
  background: #F4F0E7 !important;
  color: #3f3227 !important;
  -webkit-text-fill-color: #3f3227;
  caret-color: #3f3227;
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 0.86rem;
  letter-spacing: 0.06em;
  outline: none;
  transition: border-color 0.2s ease;
}
.jck-side__field input:focus { border-color: #3f3227; }
.jck-side__alts {
  margin-top: 18px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding-top: 18px;
  border-top: 1px solid rgba(63,50,39,0.08);
}
.jck-side__alts a {
  font-family: 'Sifonn', 'Helvetica Neue', Arial, sans-serif;
  font-size: 0.7rem;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: rgba(63,50,39,0.6) !important;
  text-decoration: none;
}
.jck-side__alts a:hover { color: #3f3227 !important; }

@media (max-width: 540px) {
  .jck-side { width: 100vw; box-shadow: none; }
}

/* ─── Mobile drawer ────────────────────────────────────────────────── */
.jck-header__drawer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #F4F0E7;
  z-index: 99;
  padding: clamp(96px, 14vh, 140px) clamp(28px, 8vw, 56px) 48px;
  transform: translateY(-100%);
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  overflow-y: auto;
}
.jck-header__drawer.is-open { transform: translateY(0); }
.jck-header__drawer-menu {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.jck-header__drawer-link {
  display: block;
  padding: 18px 0;
  border-bottom: 1px solid rgba(63,50,39,0.1);
  font-family: 'Sifonn', sans-serif;
  font-size: clamp(1.6rem, 7vw, 2.4rem);
  letter-spacing: -0.01em;
  text-transform: uppercase;
  color: #3f3227;
  text-decoration: none;
  line-height: 1;
}
.jck-header__drawer-link--secondary {
  font-size: 0.78rem;
  letter-spacing: 0.32em;
  margin-top: 24px;
  color: rgba(63,50,39,0.6);
}

/* ─── Responsive ───────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .jck-header__menu { display: none; }
  .jck-header__nav-inner { grid-template-columns: 1fr auto; }
  .jck-header__logo { justify-self: start; }
  .jck-header__utils { justify-self: end; }
  .jck-header__burger { display: inline-flex; }
}

@media (max-width: 540px) {
  .jck-header__announce-track { font-size: 0.62rem; letter-spacing: 0.28em; }
  .jck-header__util { width: 36px; height: 36px; }
}

@media (prefers-reduced-motion: reduce) {
  .jck-header__announce-track { animation: none; }
  .jck-header__nav,
  .jck-header__util,
  .jck-header__link,
  .jck-header__drawer { transition: none; }
}

{% endstylesheet %}

{% schema %}
{
  "name": "JCK Header",
  "tag": "header",
  "class": "jck-header-wrapper",
  "settings": [
    { "type": "header", "content": "Navigation" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" },

    { "type": "header", "content": "Announcement Bar" },
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "announce_1", "label": "Message 1", "default": "New Drops Weekly" },
    { "type": "text", "id": "announce_2", "label": "Message 2", "default": "Authenticated · Curated · JCK Approved" },
    { "type": "text", "id": "announce_3", "label": "Message 3", "default": "Free Shipping over $100" },
    { "type": "text", "id": "announce_4", "label": "Message 4", "default": "No Restocks · Ever" }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
